# Server
APP_NAME=mns-backend
APP_ENV=development
SERVER_HOST=0.0.0.0
SERVER_PORT=8080
SERVER_READ_TIMEOUT=10s
SERVER_WRITE_TIMEOUT=10s

# Database
DATABASE_URL=postgres://postgres:password@localhost:5432/mns_db?sslmode=disable
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=5
DB_CONN_LIFETIME=5m

# JWT
JWT_SECRET=change-this-secret-key
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=168h

# Session (opaque token, Better Auth style)
SESSION_EXPIRY=168h
# Block sign-in until the email is verified (sends verification email on attempt).
REQUIRE_EMAIL_VERIFICATION=false
# Cookie transport for web clients (Bearer header always works too).
SESSION_COOKIE_NAME=mns_session
SESSION_COOKIE_DOMAIN=
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_SAMESITE=lax

# Rate limit (in-memory, per IP)
RATE_LIMIT_WINDOW=60s
RATE_LIMIT_MAX=100

# Email (transactional). Leave EMAIL_SMTP_HOST empty in dev to log links instead.
APP_BASE_URL=http://localhost:3000
EMAIL_SMTP_HOST=
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USER=
EMAIL_SMTP_PASS=
EMAIL_FROM_ADDRESS=no-reply@example.com
EMAIL_FROM_NAME=mns-backend

# CORS / CSRF trusted origins (Better Auth style). Comma-separated.
# Supports wildcards: * (one label), ** (any), ? (one char).
# e.g. http://localhost:3000,https://*.example.com
TRUSTED_ORIGINS=http://localhost:3000
